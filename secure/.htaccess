php_value upload_max_filesize 100M
php_value max_execution_time 800
php_value post_max_size 100M
php_value max_input_time 100
php_value memory_limit 120M
php_flag  display_errors on
php_flag  display_startup_errors on
php_value error_reporting 32767
php_flag  log_errors on
php_value error_log  /home/users/qanto/qantoplus.cz/web/secure/PHP_errors.log

RewriteEngine on
RewriteCond %{HTTP_HOST} ^(www\.)?qantoplus\.cz$
RewriteCond %{HTTP_USER_AGENT} !(BlackBerry)
RewriteCond %{HTTP_USER_AGENT} !(Windows\sNT\s5\.[12])
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.qantoplus\.cz$ [NC]
RewriteRule (.*) https://www.qantoplus.cz%{REQUEST_URI} [L,R=301]
